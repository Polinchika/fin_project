FROM python:3.9-slim

RUN apt-get update && \
    apt-get install -y \
        git \
        curl \
        libgl1 \
        libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

ENV PYTHONUNBUFFERED=1

COPY . .
RUN ls -lh models/

CMD ["python", "app.py"]

